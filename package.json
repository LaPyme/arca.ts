{
  "name": "arcats-workspace",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "build": "pnpm exec turbo build",
    "typecheck": "pnpm exec turbo typecheck && pnpm typecheck:examples",
    "typecheck:examples": "pnpm exec tsc --project tsconfig.examples.json --noEmit",
    "test": "pnpm exec turbo test",
    "test:coverage": "pnpm --filter @lapyme/arca test:coverage",
    "check": "pnpm exec ultracite check",
    "fix": "pnpm exec ultracite fix",
    "pack:check": "pnpm --filter @lapyme/arca pack:check"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/node": "^25.0.8",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "ultracite": "7.4.4"
  }
}
